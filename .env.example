# =============================================================
# Coelho & Araújo — Daily Control  |  .env.example
# Para uso local: copie para .env e preencha.
# No Vercel: adicione estas variáveis em Project → Settings → Environment Variables
# =============================================================

NODE_ENV=production

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=gere_uma_string_aleatoria_de_64_chars

# Supabase — encontre em: Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_KEY=sua_service_role_key

# DATABASE_URL não é necessária no Vercel (sessão é stateless via cookie)
# Mantenha apenas se rodar localmente com sessão em PostgreSQL
